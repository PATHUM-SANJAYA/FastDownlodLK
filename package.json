{
  "name": "universal-social-downloader",
  "version": "1.0.0",
  "private": true,
  "description": "Premium SaaS-style social media video downloader using yt-dlp backend.",
  "main": "server.js",
  "scripts": {
    "start": "wget -O /usr/local/bin/yt-dlp https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp && chmod a+rx /usr/local/bin/yt-dlp && node server.js",
    "start:dev": "node server.js"
  },
  "dependencies": {
    "debug": "^4.3.6",
    "ffmpeg-static": "^5.3.0",
    "youtube-dl-exec": "^3.1.3"
  }
}