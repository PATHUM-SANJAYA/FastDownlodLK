{
  "name": "universal-social-downloader",
  "version": "1.0.0",
  "private": true,
  "description": "Premium SaaS-style social media video downloader using yt-dlp backend.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "curl -L https://github.com/yt-dlp/yt-dlp/releases/latest/download/yt-dlp -o /usr/local/bin/yt-dlp && chmod a+rx /usr/local/bin/yt-dlp && echo 'yt-dlp installed'"
  },
  "dependencies": {
    "debug": "^4.3.6",
    "ffmpeg-static": "^5.3.0",
    "youtube-dl-exec": "^3.1.3"
  }
}